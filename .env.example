# Application
AUTH_APP_ENVIRONMENT=development
AUTH_APP_VERSION=0.1.0

# HTTP
AUTH_HTTP_HOST=0.0.0.0
AUTH_HTTP_PORT=8080
AUTH_HTTP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# Set true only behind a trusted reverse proxy (enables RealIP for rate limits / audit)
AUTH_HTTP_TRUST_PROXY=false

# PostgreSQL (local/docker defaults — change in production)
AUTH_POSTGRES_HOST=localhost
AUTH_POSTGRES_PORT=5432
AUTH_POSTGRES_USER=auth
AUTH_POSTGRES_PASSWORD=auth
AUTH_POSTGRES_DATABASE=auth
AUTH_POSTGRES_SSLMODE=disable

# Redis
AUTH_REDIS_ADDR=localhost:6379
AUTH_REDIS_PASSWORD=
AUTH_REDIS_DB=0

# JWT — replace with strong random secrets (min 32 chars) before deploying
AUTH_JWT_ACCESS_SECRET=replace-with-a-strong-access-secret-min-32-chars
AUTH_JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret-min-32-chars
AUTH_JWT_ACCESS_TTL=15m
AUTH_JWT_REFRESH_TTL=168h
AUTH_JWT_ISSUER=auth-service
AUTH_JWT_REFRESH_COOKIE_NAME=refresh_token
AUTH_JWT_REFRESH_COOKIE_SECURE=false
AUTH_JWT_REFRESH_COOKIE_DOMAIN=
AUTH_JWT_REFRESH_COOKIE_PATH=/
AUTH_JWT_REFRESH_COOKIE_SAMESITE=Strict

# Security
AUTH_SECURITY_BCRYPT_COST=12
AUTH_SECURITY_RATE_LIMIT_RPM=120
AUTH_SECURITY_LOGIN_RATE_LIMIT_RPM=10
AUTH_SECURITY_REGISTER_RATE_LIMIT_RPM=30
AUTH_SECURITY_REFRESH_RATE_LIMIT_RPM=20
AUTH_SECURITY_SENSITIVE_RATE_LIMIT_RPM=5
AUTH_SECURITY_LOGIN_MAX_ATTEMPTS=5
AUTH_SECURITY_LOGIN_LOCKOUT_DURATION=15m

# Telemetry
AUTH_TELEMETRY_LOG_LEVEL=info
AUTH_TELEMETRY_METRICS_ENABLED=true
AUTH_TELEMETRY_TRACING_ENABLED=false
AUTH_TELEMETRY_OTLP_ENDPOINT=
AUTH_TELEMETRY_OTLP_INSECURE=true

# Metrics (empty = localhost only)
AUTH_HTTP_METRICS_TOKEN=
AUTH_HTTP_MAX_HEADER_BYTES=1048576
